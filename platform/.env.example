# ── Supabase ─────────────────────────────────────────────
# Projekt-URL und Keys findest du im Supabase-Dashboard unter
# Project Settings → API.

# Öffentlich (im Browser nutzbar)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Nur serverseitig! Niemals an den Client geben.
# Wird für Admin-Aktionen (z.B. Händler anlegen) verwendet.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Basis-URL der App (für QR-Code-Links / Karten-URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
